# ═══════════════════════════════════════════════
# ARS eCommerce — Apache Configuration
# ═══════════════════════════════════════════════

# ── Directory Security ─────────────────────────
Options -Indexes
ServerSignature Off

# ── Security Headers (defense-in-depth) ────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set X-XSS-Protection "1; mode=block"
    # Uncomment after SSL is confirmed on production:
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ── Block Access to Sensitive Files ────────────
<FilesMatch "\.(env|log|sql|md|git|bak|ini|sh)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Block access to hidden files (.git, .env, etc.)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule (^\.|/\.) - [F]
</IfModule>

# ── Block Direct Access to Sensitive Directories ─
# Protect logs directory
<IfModule mod_rewrite.c>
    RewriteRule ^logs/ - [F,L]
    RewriteRule ^config/ - [F,L]
    RewriteRule ^includes/ - [F,L]
</IfModule>

# ── HTTPS Redirect (uncomment for production) ──
# <IfModule mod_rewrite.c>
#     RewriteCond %{HTTPS} off
#     RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>

# ══════════════════════════════════════════════
# URL Rewriting Rules
# ══════════════════════════════════════════════
RewriteEngine On

# Route API requests to api/index.php (handles both root and subfolder installs)
RewriteRule ^(?:.*/)?api/(.*)$ api/index.php [L,QSA]

# Route backend clean URLs explicitly (backend is a real directory)
RewriteRule ^backend/check-login$ index.php [L,QSA]
RewriteRule ^backend/dashboard-stats$ index.php [L,QSA]

# Allow access to real files and directories (CSS, JS, Images)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Redirect everything else to index.php
RewriteRule ^(.*)$ index.php [L,QSA]

