# ═══════════════════════════════════════════════
# ARS eCommerce — Apache Configuration
# ═══════════════════════════════════════════════

# ── Directory Security ─────────────────────────
Options -Indexes
ServerSignature Off

# ── PWA MIME Types ─────────────────────────────
<IfModule mod_mime.c>
    AddType application/javascript .js
    AddType application/wasm .wasm
</IfModule>

# ── Security Headers (defense-in-depth) ────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set X-XSS-Protection "1; mode=block"
    # Uncomment after SSL is confirmed on production:
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ── Block Access to Sensitive Files ────────────
<FilesMatch "\.(env|log|sql|md|git|bak|ini|sh)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# ══════════════════════════════════════════════
# URL Rewriting Rules (single consolidated block)
# ══════════════════════════════════════════════
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct browser access to hidden files (.git, .env, etc.)
    RewriteRule (^\.|/\.) - [F,L]

    # Block direct browser access to sensitive directories
    RewriteRule ^logs(/|$) - [F,L]
    RewriteRule ^config(/|$) - [F,L]

    # Block direct browser access to includes/ ONLY for HTTP requests
    # (PHP require/include still works since it's filesystem, not HTTP)
    RewriteCond %{REQUEST_URI} ^(.*/)?includes/ [NC]
    RewriteRule .* - [F,L]

    # ── HTTPS Redirect (uncomment for production) ──
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Allow access to real files and directories FIRST (admin/api/*.php, CSS, JS, images, uploads)
    # This must come before the API routing rule so admin/api/ files are served directly.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route API requests to api/index.php (only reaches here for non-existent virtual paths)
    RewriteRule ^(?:.*/)?api/(.*)$ api/index.php [L,QSA]

    # Route backend clean URLs explicitly (backend is a real directory)
    RewriteRule ^backend/check-login$ index.php [L,QSA]
    RewriteRule ^backend/dashboard-stats$ index.php [L,QSA]

    # Allow PWA critical files
    RewriteRule ^sw\.js$ - [L]
    RewriteRule ^manifest\.json$ - [L]

    # Redirect everything else to index.php (clean URL router)
    RewriteRule ^(.*)$ index.php [L,QSA]
</IfModule>
