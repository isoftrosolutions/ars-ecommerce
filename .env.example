# ──────────────────────────────────────────────
# ARS eCommerce — Environment Configuration Template
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your production values.
# NEVER commit your .env file to version control!

# Application
APP_ENV=production
APP_DEBUG=false
APP_URL=https://easyshoppingars.com

# Database
DB_HOST=localhost
DB_NAME=ars_ecommerce
DB_USER=your_db_user
DB_PASS=your_strong_password
DB_CHARSET=utf8mb4

# Session
SESSION_LIFETIME=0
SESSION_SECURE=true

# SMTP (loaded from DB site_settings, but fallback values here)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_ENCRYPTION=tls
