{
  "name": "Easy Shopping A.R.S - Online Shopping in Nepal",
  "short_name": "ARS Shop",
  "description": "Nepal's trusted online store. Shop electronics, fashion, home goods with fast delivery. eSewa & COD accepted.",
  "start_url": "/ars/",
  "scope": "/ars/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "background_color": "#1e293b",
  "theme_color": "#ea6c00",
  "orientation": "portrait-primary",
  "lang": "en-NP",
  "dir": "ltr",
  "categories": ["shopping", "e-commerce"],
  "prefer_related_applications": false,
  "icons": [
    {
      "src": "/ars/public/assets/img/pwa-icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/ars/public/assets/img/pwa-icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/ars/public/assets/img/pwa-icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/ars/public/assets/img/screenshot-desktop.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Desktop View"
    },
    {
      "src": "/ars/public/assets/img/screenshot-mobile.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Mobile View"
    }
  ],
  "shortcuts": [
    {
      "name": "Shop Now",
      "short_name": "Shop",
      "description": "Browse our product catalog",
      "url": "/ars/shop.php",
      "icons": [{ "src": "/ars/public/assets/img/pwa-icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "My Cart",
      "short_name": "Cart",
      "description": "View your shopping cart",
      "url": "/ars/cart.php",
      "icons": [{ "src": "/ars/public/assets/img/pwa-icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "My Orders",
      "short_name": "Orders",
      "description": "Track your orders",
      "url": "/ars/orders.php",
      "icons": [{ "src": "/ars/public/assets/img/pwa-icon-192.png", "sizes": "192x192" }]
    }
  ],
  "related_applications": [],
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "edge_side_panel": {
    "preferred_width": 480
  }
}
